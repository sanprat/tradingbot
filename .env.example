# Trading mode (paper or live) - paper is default for safety
ENVIRONMENT=paper

# Default broker when not specified in webhook
DEFAULT_BROKER=paper

# TradingView webhook secret - CHANGE THIS IN PRODUCTION
TRADINGVIEW_WEBHOOK_SECRET=your-webhook-secret-here

# Dhan Broker (required for live trading with Dhan)
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# Shoonya Broker (required for live trading with Shoonya)
SHOONYA_USER_ID=your_shoonya_user_id
SHOONYA_PASSWORD=your_shoonya_password
SHOONYA_API_KEY=your_shoonya_api_key
SHOONYA_VENDOR_CODE=your_shoonya_vendor_code
SHOONYA_IMEI=your_shoonya_imei
SHOONYA_TOTP_SECRET=your_shoonya_totp_secret

# Risk Controls
MAX_ORDER_QUANTITY=10000
MAX_ORDER_NOTIONAL=1000000
MAX_DAILY_LOSS=5000
MAX_OPEN_POSITIONS=10

# Optional: Server Configuration
API_PORT=8001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000